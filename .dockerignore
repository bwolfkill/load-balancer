# Git
.git/
.gitignore

# Environment files — never bake secrets into an image
.env
.env.*
!.env.example

# Editor/IDE
.idea/
.vscode/

# Built binaries — the Dockerfile builds these inside the image
loadbalancer
*.exe
*.dll
*.so
*.dylib

# Air live reload output
tmp/

# Test artifacts — not needed at runtime
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# Docker files themselves
Dockerfile*
.dockerignore
docker-compose*.yml
compose.yaml

# Local development tooling
Makefile
.air.toml

# Kubernetes manifests — not needed at runtime
k8s/

# Observability config — not needed at runtime
observability/

# README and docs — not needed at runtime
*.md
